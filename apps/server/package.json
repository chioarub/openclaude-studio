{
  "name": "openclaude-studio",
  "version": "0.3.0",
  "description": "Read-only local API bridge for the OpenClaude Studio dashboard.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chioarub/openclaude-studio.git",
    "directory": "apps/server"
  },
  "bugs": {
    "url": "https://github.com/chioarub/openclaude-studio/issues"
  },
  "homepage": "https://github.com/chioarub/openclaude-studio#readme",
  "keywords": [
    "openclaude",
    "studio",
    "local",
    "dashboard",
    "logs",
    "diagnostics"
  ],
  "bin": {
    "openclaude-studio": "dist/cli.js",
    "openclaude-studio-server": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json && chmod +x dist/cli.js",
    "dev": "tsx watch src/cli.ts --port 43110",
    "lint": "npm run build -w @openclaude-studio/shared && tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "start": "node dist/cli.js",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsx": "^4.22.4",
    "vitest": "^3.2.6"
  }
}
